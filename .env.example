# ============================================
# YieldMind Protocol — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Never commit .env to git!

# --- Hedera ---
# Set to 'testnet' or 'mainnet'
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=302e020100300506032b6570...
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# --- Hedera EVM (raw hex private key for Hardhat / ethers.js) ---
HEDERA_PRIVATE_KEY_HEX=0x...

# --- HCS Topics (auto-created on first run, then paste IDs here) ---
HCS_GLOBAL_TOPIC_ID=
HCS_SESSION_TOPIC_PREFIX=yieldmind-session

# --- LLM (OpenRouter — free tier) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Bonzo Finance ---
# Bonzo LendingPool EVM address (auto-configured per network, override if needed)
# Testnet: 0x6bf7b21145cbd7bb0b9916e6eb24eda8a675d7c0 (derived from 0.0.2664875)
# Mainnet: (set when deploying to mainnet)
BONZO_LENDING_POOL_EVM_ADDRESS=0x6bf7b21145cbd7bb0b9916e6eb24eda8a675d7c0
BONZO_PROTOCOL_DATA_PROVIDER=

# --- Frontend ---
# MUST match HEDERA_NETWORK
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
NEXT_PUBLIC_BONZO_LENDING_POOL_ADDRESS=0x6bf7b21145cbd7bb0b9916e6eb24eda8a675d7c0

# --- Legacy YieldMindVault Contract (optional, for backward compat) ---
NEXT_PUBLIC_VAULT_CONTRACT_ADDRESS=0x29d115707bEe4adAa159Fe757B7dA4ffF8cc432A
