# ============================================
# YieldMind Protocol — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Never commit .env to git!

# --- Hedera ---
# Set to 'testnet' or 'mainnet'
HEDERA_NETWORK=mainnet
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=302e020100300506032b6570...
HEDERA_MIRROR_NODE_URL=https://mainnet.mirrornode.hedera.com

# --- Hedera EVM (raw hex private key for Hardhat / ethers.js) ---
HEDERA_PRIVATE_KEY_HEX=0x...

# --- HCS Topics (auto-created on first run, then paste IDs here) ---
HCS_GLOBAL_TOPIC_ID=
HCS_SESSION_TOPIC_PREFIX=yieldmind-session

# --- LLM (OpenRouter — free tier) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# --- Bonzo Finance ---
# Bonzo LendingPool EVM address (per-network)
# Testnet: 0xf67DBe9bD1B331cA379c44b5562EAa1CE831EbC2 (0.0.4999355)
# Mainnet: 0x236897c518996163E7b313aD21D1C9fCC7BA1afc (0.0.7308459)
BONZO_LENDING_POOL_EVM_ADDRESS=0x236897c518996163E7b313aD21D1C9fCC7BA1afc
BONZO_PROTOCOL_DATA_PROVIDER=0x78feDC4D7010E409A0c0c7aF964cc517D3dCde18

# --- Frontend ---
# MUST match HEDERA_NETWORK
NEXT_PUBLIC_HEDERA_NETWORK=mainnet
NEXT_PUBLIC_MIRROR_NODE_URL=https://mainnet.mirrornode.hedera.com
NEXT_PUBLIC_BONZO_LENDING_POOL_ADDRESS=0x236897c518996163E7b313aD21D1C9fCC7BA1afc

# --- WalletConnect (for HashPack / Kabila support) ---
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Legacy YieldMindVault Contract (testnet only, leave blank for mainnet) ---
# NEXT_PUBLIC_VAULT_CONTRACT_ADDRESS=0x29d115707bEe4adAa159Fe757B7dA4ffF8cc432A
